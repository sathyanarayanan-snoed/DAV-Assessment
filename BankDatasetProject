import pandas as pd
import matplotlib.pyplot as plt
from sklearn.linear_model import LinearRegression
from sklearn.metrics import r2_score

# Sample dataset of 10 customers
data = {
    'Annual_Income': [2.5, 3.0, 3.5, 4.0, 4.5, 5.0, 5.5, 6.0, 6.5, 7.0],
    'Loan_Amount': [1.5, 1.8, 2.1, 2.5, 2.9, 3.3, 3.7, 4.1, 4.5, 4.9]
}

# Create DataFrame
df = pd.DataFrame(data)

print("Dataset:")
print(df)

# Dataset Information
print("\nDataset Information:")
print(df.info())

# Check Missing Values
print("\nMissing Values:")
print(df.isnull().sum())

# Statistical Summary
print("\nStatistical Summary:")
print(df.describe())

# Independent variable (X) and Dependent variable (y)
X = df[['Annual_Income']]
y = df['Loan_Amount']

# Create and train Linear Regression model
model = LinearRegression()
model.fit(X, y)

# Predict Loan Amount
y_pred = model.predict(X)

# Calculate R² Score
r2 = r2_score(y, y_pred)

print("\nModel Performance")
print("R² Score:", round(r2, 4))
print("Slope (Coefficient):", model.coef_[0])
print("Intercept:", model.intercept_)

# Predict loan amount for a customer with annual income of 5.8 lakhs
income = [[5.8]]
predicted_loan = model.predict(income)

print("\nPredicted Loan Amount for Annual Income of 5.8 Lakhs:")
print(round(predicted_loan[0], 2), "Lakhs")

# Visualization
plt.scatter(X, y, color='blue', label='Actual Data')
plt.plot(X, y_pred, color='red', linewidth=2,
         label='Regression Line')

plt.title('Annual Income vs Loan Amount')
plt.xlabel('Annual Income (Lakhs)')
plt.ylabel('Loan Amount (Lakhs)')
plt.legend()
plt.grid(True)

plt.show()
